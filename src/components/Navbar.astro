---
// src/components/Navbar.astro
---
<header class="fixed w-full z-50 top-0 transition-all duration-500 bg-white/60 backdrop-blur-2xl border-b border-white/80 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <a href="/" class="text-2xl font-black text-slate-900 tracking-tighter hover:opacity-80 transition-opacity">
      JUNGLE<span class="text-blue-600">ELITE</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8 font-semibold text-slate-600 text-[15px]">
      <a href="/" class="hover:text-blue-600 transition-colors relative group py-2">Home</a>
      
      <a href="/about" class="hover:text-blue-600 transition-colors relative group py-2">About us</a>
      
      <a href="/design-cases" class="hover:text-blue-600 transition-colors relative group py-2">Design cases</a>

      <div class="relative group py-6">
        <a href="/products" class="hover:text-blue-600 transition-colors flex items-center gap-1 cursor-pointer">
          Products
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-70 group-hover:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>
        <div class="absolute top-[70px] left-1/2 -translate-x-1/2 w-52 bg-white/95 backdrop-blur-xl border border-slate-100 shadow-[0_20px_40px_rgb(0,0,0,0.08)] rounded-2xl opacity-0 invisible scale-95 group-hover:opacity-100 group-hover:visible group-hover:scale-100 transition-all duration-300 flex flex-col p-2">
          <a href="/products/backpack" class="px-4 py-2.5 text-slate-600 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-colors font-medium">Backpack</a>
          <a href="/products/softside-luggage" class="px-4 py-2.5 text-slate-600 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-colors font-medium">Softside luggage</a>
          <a href="/products/makeup-case" class="px-4 py-2.5 text-slate-600 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-colors font-medium">Makeup case</a>
        </div>
      </div>

      <div class="relative group py-6">
        <div class="hover:text-blue-600 transition-colors flex items-center gap-1 cursor-pointer">
          News&blogs
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-70 group-hover:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </div>
        <div class="absolute top-[70px] left-1/2 -translate-x-1/2 w-44 bg-white/95 backdrop-blur-xl border border-slate-100 shadow-[0_20px_40px_rgb(0,0,0,0.08)] rounded-2xl opacity-0 invisible scale-95 group-hover:opacity-100 group-hover:visible group-hover:scale-100 transition-all duration-300 flex flex-col p-2">
          <a href="/news" class="px-4 py-2.5 text-slate-600 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-colors font-medium">News</a>
          <a href="/blogs" class="px-4 py-2.5 text-slate-600 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-colors font-medium">Blogs</a>
        </div>
      </div>

      <a href="/contact" class="hover:text-blue-600 transition-colors relative group py-2">Contact us</a>
    </nav>

    <a
      href="https://wa.me/8615913136225"
      target="_blank"
      class="group flex items-center gap-2 bg-gradient-to-r from-[#25D366] to-[#1DA851] hover:from-[#1ebd57] hover:to-[#178c43] text-white px-6 py-2.5 rounded-full font-bold transition-all duration-300 shadow-[0_8px_20px_rgba(37,211,102,0.3)] hover:shadow-[0_12px_25px_rgba(37,211,102,0.45)] hover:-translate-y-0.5"
